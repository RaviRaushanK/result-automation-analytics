<!--
  SRAAS Header – Windows 11 inspired
  Left: Logo + Branding
  Right: Theme Toggle + Admin Dropdown
-->
<header class="app-header">
  <div class="header-inner">
    <!-- LEFT: Hamburger + Brand -->
    <div class="header-left">
      <button class="sidebar-toggle-btn" id="sidebarToggle" aria-label="Toggle sidebar" aria-expanded="false" title="Toggle sidebar">
        <span class="material-icons">menu</span>
      </button>

      <a class="header-brand" href="/">
        <div class="brand-icon">
          <span class="material-icons">analytics</span>
        </div>
        <div class="brand-text">
          <span class="brand-title">SRAS</span>
          <span class="brand-subtitle">Student Result Analysis System</span>
        </div>
      </a>
    </div>

    <!-- RIGHT: Controls -->
    <div class="header-controls">
      <!-- Theme Toggle -->
      <button class="theme-toggle-btn" onclick="window.toggleTheme()" aria-label="Toggle theme" title="Toggle theme">
        <span class="material-icons">dark_mode</span>
      </button>

      <!-- Admin Dropdown -->
      <% if (typeof user !== 'undefined' && user) { %>
      <div class="dropdown">
        <button class="admin-dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
          <span class="material-icons admin-avatar">account_circle</span>
          <span class="admin-name"><%= user.name || 'Admin' %></span>
          <span class="material-icons dropdown-arrow">arrow_drop_down</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
          <li><a class="dropdown-item" href="/profile">
            <span class="material-icons dropdown-item-icon">person</span> Profile
          </a></li>
          <li><hr class="dropdown-divider"></li>
          <li><a class="dropdown-item" href="/auth/logout">
            <span class="material-icons dropdown-item-icon">logout</span> Logout
          </a></li>
        </ul>
      </div>
      <% } else { %>
      <a href="/auth/login" class="btn btn-sm btn-primary">Sign In</a>
      <% } %>
    </div>
  </div>
</header>