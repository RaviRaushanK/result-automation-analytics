<div class="container-fluid py-5">
    <div class="row justify-content-center align-items-center min-vh-50">
        <div class="col-12 col-md-8 col-lg-6 text-center">
            <div class="mb-4">
                <i class="material-icons" style="font-size: 120px; color: var(--primary-brand);">search_off</i>
            </div>
            <h1 class="display-1 fw-bold mb-3" style="color: var(--text-primary);">404</h1>
            <h2 class="h3 mb-3" style="color: var(--text-primary);">Page Not Found</h2>
            <p class="lead mb-4" style="color: var(--text-secondary);">
                The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
            </p>
            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                <% if (typeof user !== 'undefined' && user) { %>
                    <a href="/dashboard" class="btn btn-primary btn-lg px-4">
                        <i class="material-icons me-2">dashboard</i>
                        Return to Dashboard
                    </a>
                <% } else { %>
                    <a href="/" class="btn btn-primary btn-lg px-4">
                        <i class="material-icons me-2">home</i>
                        Return to Home
                    </a>
                <% } %>
                <button onclick="history.back()" class="btn btn-outline-secondary btn-lg px-4">
                    <i class="material-icons me-2">arrow_back</i>
                    Go Back
                </button>
            </div>
            <div class="mt-5">
                <p class="small" style="color: var(--text-secondary);">
                    If you believe this is an error, please contact the system administrator.
                </p>
            </div>
        </div>
    </div>
</div>