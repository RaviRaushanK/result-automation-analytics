<div class="container-fluid py-5">
    <div class="row justify-content-center align-items-center min-vh-50">
        <div class="col-12 col-md-8 col-lg-6 text-center">
            <div class="mb-4">
                <i class="material-icons" style="font-size: 120px; color: var(--color-danger);">error_outline</i>
            </div>
            <h1 class="display-1 fw-bold mb-3" style="color: var(--text-primary);">500</h1>
            <h2 class="h3 mb-3" style="color: var(--text-primary);">Internal Server Error</h2>
            <p class="lead mb-4" style="color: var(--text-secondary);">
                Something went wrong on our end. We are sorry for the inconvenience. Please try again later or contact the system administrator.
            </p>
            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                <a href="/" class="btn btn-primary btn-lg px-4">
                    <i class="material-icons me-2">home</i>
                    Return to Home
                </a>
                <button onclick="location.reload()" class="btn btn-outline-secondary btn-lg px-4">
                    <i class="material-icons me-2">refresh</i>
                    Try Again
                </button>
            </div>
            <div class="mt-5">
                <p class="small" style="color: var(--text-secondary);">
                    If this problem persists, please contact the system administrator with the error details and time of occurrence.
                </p>
            </div>
        </div>
    </div>
</div>