{
  "name": "result-automation-analytics",
  "version": "1.0.0",
  "description": "Automates student result processing with analytics and reporting features",
  "main": "app.js",
  "scripts": {
    "setup": "node scripts/bootstrap-db.js && npx sequelize-cli db:migrate && npm run init-db && npx sequelize-cli db:seed:all",
    "migrate": "npx sequelize-cli db:migrate",
    "seed": "npx sequelize-cli db:seed:all",
    "init-db": "node scripts/runInit.js",
    "start": "node app.js"
  },
